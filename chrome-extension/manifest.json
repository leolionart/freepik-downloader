{
  "manifest_version": 3,
  "name": "Freepik Direct Downloader",
  "version": "1.0.0",
  "description": "Download Freepik resources directly from the page using your official API Key. No redirect, no IP blocks.",
  "permissions": ["tabs", "storage", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://*.freepik.com/*",
    "https://api.freepik.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Freepik Downloader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.freepik.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
